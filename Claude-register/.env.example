# 使用 `openssl rand -hex 32` 生成，不要使用此示例值上线。
WEBUI_TOKEN=replace-with-a-long-random-token

# 默认只允许宿主机上的反向代理访问；直接开放端口时改为 0.0.0.0。
BIND_ADDRESS=127.0.0.1
WEBUI_PORT=8000
TZ=Asia/Shanghai

# 仅填写实际反向代理的容器 IP/CIDR；不要在线上设为 *。
FORWARDED_ALLOW_IPS=127.0.0.1

# Linux 部署机当前用户的 UID/GID，可通过 `id -u` 和 `id -g` 查看。
PUID=1000
PGID=1000
